{
  "name": "intentlang",
  "displayName": "IntentLang",
  "description": "Language support for IntentLang — syntax highlighting, snippets, and diagnostics for .intent specification files",
  "version": "0.1.0",
  "publisher": "krakenhavoc",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/krakenhavoc/IntentLang"
  },
  "bugs": {
    "url": "https://github.com/krakenhavoc/IntentLang/issues"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters"
  ],
  "keywords": [
    "intentlang",
    "intent",
    "specification",
    "contracts",
    "formal-verification"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "intent",
        "aliases": [
          "IntentLang",
          "intent"
        ],
        "extensions": [
          ".intent"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icon.png",
          "dark": "./icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "intent",
        "scopeName": "source.intent",
        "path": "./syntaxes/intent.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "intent",
        "path": "./snippets/intent.json"
      }
    ],
    "configuration": {
      "title": "IntentLang",
      "properties": {
        "intentlang.server.path": {
          "type": "string",
          "default": "",
          "description": "Path to the intent-lsp binary. If empty, uses 'intent-lsp' from PATH."
        },
        "intentlang.server.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the IntentLang Language Server for diagnostics and navigation."
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --watch",
    "package": "vsce package",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  }
}
